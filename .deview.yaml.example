# 프로젝트별 설정 (선택사항)
# 이 파일이 없어도 기본값으로 동작합니다.
# 사용할 프로젝트 루트에 .deview.yaml 으로 복사하여 사용하세요.
#
# 임베딩 provider, API 키 등 서버 설정은 ~/.deview/config.yaml 에서 관리합니다.

# Scope: 생략 시 git remote URL에서 자동 추론
# scope: "team/my-project"

# 인덱싱 설정
ingestion:
  git:
    target_branch: "main"
    # max_commits: 1000  # 전체 히스토리 대신 최근 N개만 인덱싱
